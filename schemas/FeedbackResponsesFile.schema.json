{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "./FeedbackResponsesFile.schema.json",
  "type": "object",
  "properties": {
    "format": {
      "$ref": "#/$defs/schema0"
    },
    "feedbackMetadata": {
      "$ref": "#/$defs/schema1"
    },
    "responses": {
      "$ref": "#/$defs/schema11"
    }
  },
  "required": [
    "format",
    "feedbackMetadata",
    "responses"
  ],
  "additionalProperties": false,
  "title": "FeedbackResponsesFile",
  "description": "JSON import for feedback responses",
  "$defs": {
    "schema0": {
      "type": "string",
      "const": "THEYDO_FEEDBACK_RESPONSES_V1"
    },
    "schema1": {
      "type": "object",
      "properties": {
        "feedbackName": {
          "$ref": "#/$defs/schema2"
        },
        "feedbackId": {
          "$ref": "#/$defs/schema3"
        },
        "feedbackFields": {
          "$ref": "#/$defs/schema4"
        },
        "convertAllRowsToQuotes": {
          "$ref": "#/$defs/schema10"
        }
      },
      "required": [
        "feedbackName",
        "feedbackId",
        "feedbackFields"
      ],
      "additionalProperties": false
    },
    "schema2": {
      "type": "string"
    },
    "schema3": {
      "type": "string"
    },
    "schema4": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "fieldId": {
            "$ref": "#/$defs/schema5"
          },
          "fieldName": {
            "$ref": "#/$defs/schema6"
          },
          "fieldType": {
            "$ref": "#/$defs/schema7"
          },
          "tagGroupTitle": {
            "$ref": "#/$defs/schema8"
          },
          "required": {
            "$ref": "#/$defs/schema9"
          }
        },
        "required": [
          "fieldId",
          "fieldName",
          "required"
        ],
        "additionalProperties": false
      }
    },
    "schema5": {
      "type": "string"
    },
    "schema6": {
      "type": "string",
      "minLength": 1
    },
    "schema7": {
      "default": "TEXT",
      "type": "string",
      "enum": [
        "TEXT",
        "TAG_GROUP",
        "PERSONA",
        "IGNORE"
      ]
    },
    "schema8": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "schema9": {
      "type": "boolean"
    },
    "schema10": {
      "type": "boolean"
    },
    "schema11": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "responseId": {
            "type": "string"
          },
          "responseDateTime": {
            "type": "string",
            "format": "date-time",
            "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$"
          },
          "responseFields": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "fieldId": {
                  "type": "string"
                },
                "textValue": {
                  "type": "string"
                }
              },
              "required": [
                "fieldId",
                "textValue"
              ],
              "additionalProperties": false
            }
          }
        },
        "required": [
          "responseId",
          "responseDateTime",
          "responseFields"
        ],
        "additionalProperties": false
      }
    }
  }
}